{
  "name": "dcarbone/php-consul-api",
  "type": "library",
  "description": "PHP client for the Consul HTTP API",
  "homepage": "https://github.com/dcarbone/php-consul-api",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Daniel Carbone",
      "email": "daniel.p.carbone@gmail.com"
    }
  ],
  "keywords": [
    "consul",
    "consul-api",
    "php-consul-api"
  ],
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "dcarbone/gotime": "^v1.0.1",
    "dcarbone/gohttp": "^v1.0.0",
    "guzzlehttp/guzzle": "^7.4",
    "guzzlehttp/psr7": "^2.4"
  },
  "autoload": {
    "files": [
      "src/PHPLib/funcs.php"
    ],
    "psr-4": {
      "DCarbone\\PHPConsulAPI\\": "src/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5 || ^12.0"
  },
  "autoload-dev": {
    "files": [
      "tests/funcs.php"
    ],
    "psr-4": {
      "DCarbone\\PHPConsulAPI\\": "src/",
      "DCarbone\\PHPConsulAPITests\\": "tests/"
    }
  },
  "scripts": {
    "php-cs-fixer": "tools/php-cs-fixer/vendor/bin/php-cs-fixer fix --config .php-cs-fixer.php src/",
    "phpstan": "tools/phpstan/vendor/bin/phpstan analyze -c phpstan.neon --memory-limit=512M --no-progress",
    "psalm": "tools/psalm/vendor/bin/psalm --config=psalm.xml --no-progress"
  }
}